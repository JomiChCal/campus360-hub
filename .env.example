# Google Sheets (wizard de turnos)
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Cliente (opcionales)
NEXT_PUBLIC_ZOOM_MEETING_ID=89419717339

# Desarrollo: simular horario de atención
# Valores: open | lunch | after-hours
# NEXT_PUBLIC_MOCK_BUSINESS_HOURS=open

# --- Portal académico: proveedor de datos (obligatorio) ---
ACADEMIC_SERVICES_DATA_PROVIDER=neon

# Neon — solo cuando ACADEMIC_SERVICES_DATA_PROVIDER=neon
# Usar URL con pooling en Vercel: ...-pooler.neon.tech
# Neon pooled: usar sslmode=verify-full (evita warning de pg con sslmode=require)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/neondb?sslmode=verify-full"

# NextAuth / Auth.js
AUTH_SECRET="generar-con: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Admin credentials (panel /administrativo)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="cambiar-en-produccion"
