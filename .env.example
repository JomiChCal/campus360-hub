# Google Sheets (wizard de turnos)
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Cliente (opcionales)
NEXT_PUBLIC_ZOOM_MEETING_ID=89419717339

# Desarrollo: simular horario de atención
# Valores: open | lunch | after-hours
# NEXT_PUBLIC_MOCK_BUSINESS_HOURS=open

# --- Portal académico: proveedor de datos (obligatorio) ---
ACADEMIC_SERVICES_DATA_PROVIDER=microsoft

# NextAuth / Auth.js
AUTH_SECRET="generar-con: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Admin credentials (panel /administrativo)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="cambiar-en-produccion"
# Webhook shared secret for Microsoft Lists / Power Automate integration
MICROSOFT_LISTS_WEBHOOK_SECRET=

# Microsoft Graph pull sync (servidor — sin Power Automate)
# MICROSOFT_TENANT_ID=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_SHAREPOINT_HOST=utpl.sharepoint.com
# MICROSOFT_SHAREPOINT_SITE_PATH=/sites/Encuestasdesatisfaccin
# Secreto para POST /api/microsoft-lists/pull (cron o manual)
# MICROSOFT_SYNC_CRON_SECRET=

# Microsoft provider modes:
# - prototype | fixture | mock -> reads from local JSON fixture
# - powerautomate | flow | direct -> fetches live from Power Automate trigger (MICROSOFT_FLOW_URL)
MICROSOFT_PROVIDER_MODE=powerautomate
# URL del trigger HTTP del flow de Power Automate (solo cuando MICROSOFT_PROVIDER_MODE=powerautomate)
MICROSOFT_FLOW_URL=https://default6eeb49aa436d43e6becdbbdf79e507.7d.environment.api.powerplatform.com:443/powerautomate/automations/direct/workflows/3977fdaf14594732987a5a24f67d4682/triggers/manual/paths/invoke?api-version=1&sp=%2Ftriggers%2Fmanual%2Frun&sv=1.0&sig=XubzzD45bZCtnSPopiVpThi7q-FL7gqjXQdhoQhQl6g
