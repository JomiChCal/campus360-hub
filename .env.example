# Secret para que Power Automate actualice horarios (POST /api/refresh-config o /api/horario)
REFRESH_SECRET=genera_una_clave_larga_y_aleatoria

# Producción (Vercel): Storage → Marketplace → Upstash Redis
# Vercel inyecta KV_REST_API_URL y KV_REST_API_TOKEN al conectar la base.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# Alternativa directa Upstash:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ID de reunión Zoom (servidor o cliente)
ZOOM_MEETING_ID=89419717339
# NEXT_PUBLIC_ZOOM_MEETING_ID=89419717339

# Power Automate webhooks salientes (turnos)
PA_CREAR_TURNO_URL=
PA_CREAR_AUTOGESTION_URL=
PA_CREAR_FUERA_HORARIO_URL=

# Opcional: forzar estado de horario en desarrollo (open | lunch | after-hours)
# NEXT_PUBLIC_MOCK_BUSINESS_HOURS=open
