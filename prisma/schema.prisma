generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ScheduleMode {
  normal
  extended
  test
}

model ScheduleConfig {
  id        Int          @id @default(1)
  mode      ScheduleMode @default(normal)
  testState String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum ServiceStatus {
  draft
  published
  needs_review
}

enum ServiceResult {
  GUIA
  TURNO
}

model ServiceCategory {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  name        String
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  services    Service[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Service {
  id              Int                  @id @default(autoincrement())
  sourceKey       String               @unique
  sourceRowIndex  Int?
  title           String
  slug            String
  description     String?
  programs        String[]             @default([])
  modalityLevel   String?
  responseTime    String?
  cost            String?
  note            String?
  calendarText    String?
  status          ServiceStatus        @default(draft)
  sortOrder       Int                  @default(0)
  isActive        Boolean              @default(true)
  result          ServiceResult        @default(TURNO)
  category        ServiceCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  categoryId      Int
  requirements    ServiceRequirement[]
  requirementTabs ServiceRequirementTab[]
  periods         ServicePeriod[]
  manuals         ServiceManual[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([categoryId, slug])
  @@index([categoryId, sortOrder])
}

model ServiceRequirement {
  id        Int     @id @default(autoincrement())
  text      String
  sortOrder Int     @default(0)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId Int
}

model ServiceRequirementTab {
  id        Int                      @id @default(autoincrement())
  tabName   String
  title     String?
  sortOrder Int                      @default(0)
  service   Service                  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId Int
  items     ServiceRequirementItem[]
  guides    ServiceRequirementTabGuide[]
}

model ServiceRequirementItem {
  id        Int                   @id @default(autoincrement())
  text      String
  pdfUrl    String?
  sortOrder Int                   @default(0)
  tab       ServiceRequirementTab @relation(fields: [tabId], references: [id], onDelete: Cascade)
  tabId     Int
}

model ServiceRequirementTabGuide {
  id        Int                   @id @default(autoincrement())
  label     String
  url       String
  sortOrder Int                   @default(0)
  tab       ServiceRequirementTab @relation(fields: [tabId], references: [id], onDelete: Cascade)
  tabId     Int
}

model ServicePeriod {
  id         Int                     @id @default(autoincrement())
  name       String
  sortOrder  Int                     @default(0)
  service    Service                 @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId  Int
  modalities ServicePeriodModality[]
}

model ServicePeriodModality {
  id             Int           @id @default(autoincrement())
  modality       String
  requestWindow  String?
  responseWindow String?
  enabledFrom    DateTime?     @db.Date
  enabledTo      DateTime?     @db.Date
  sortOrder      Int           @default(0)
  period         ServicePeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  periodId       Int
}

model ServiceManual {
  id        Int     @id @default(autoincrement())
  label     String
  url       String
  sortOrder Int     @default(0)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId Int
}
